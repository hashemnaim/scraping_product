{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "global-state.schema.json",
  "title": "GlobalIdState",
  "type": "object",
  "required": ["last_used_id", "category_ranges", "updated_at"],
  "properties": {
    "last_used_id": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" },
    "category_ranges": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/CategoryRange"
      }
    }
  },
  "$defs": {
    "CategoryRange": {
      "type": "object",
      "required": ["id_start", "id_end", "product_count", "excel_path", "images_dir"],
      "properties": {
        "id_start": { "type": "integer", "minimum": 1 },
        "id_end": { "type": "integer", "minimum": 1 },
        "product_count": { "type": "integer", "minimum": 0 },
        "excel_path": { "type": "string" },
        "images_dir": { "type": "string" },
        "freed_ids": {
          "type": "array",
          "items": { "type": "integer" }
        }
      }
    }
  }
}
