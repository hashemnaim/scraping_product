{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "category-mapping-rules.schema.json",
  "title": "CategoryMappingRule",
  "type": "object",
  "required": ["module_id", "pattern", "sub_category_id", "priority"],
  "properties": {
    "module_id": { "type": "integer", "minimum": 1 },
    "pattern": { "type": "string", "minLength": 2 },
    "sub_category_id": { "type": "integer", "minimum": 1 },
    "priority": { "type": "integer", "default": 0 },
    "active": { "type": "boolean", "default": true },
    "match_mode": {
      "type": "string",
      "enum": ["contains", "equals"],
      "default": "contains"
    }
  }
}
